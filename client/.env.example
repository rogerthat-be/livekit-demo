# Client URLs (worden ingebakken tijdens build)
# Local dev (zelfde host):
# VITE_TOKEN_URL=/token
# VITE_LIVEKIT_URL=ws://localhost:7880

# Productie met apart gehoste client (bv. GitHub Pages):
VITE_TOKEN_URL=https://livekit.jouwdomein.com/token
VITE_LIVEKIT_URL=wss://livekit.jouwdomein.com
VITE_STUN_URL=stun:turn.jouwdomein.com:3478
VITE_TURN_URL=turn:turn.jouwdomein.com:3478?transport=udp,turn:turn.jouwdomein.com:3478?transport=tcp
VITE_TURN_USERNAME=turnuser
VITE_TURN_PASSWORD=change-me
# Debug: force relay only
# VITE_ICE_TRANSPORT_POLICY=relay

