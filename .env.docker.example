# LiveKit API Credentials
LIVEKIT_API_KEY=replace-with-api-key
LIVEKIT_API_SECRET=replace-with-api-secret
FRONTEND_ORIGINS=https://stream.jouwdomein.com
VITE_TOKEN_URL=https://api.jouwdomein.com/token
VITE_LIVEKIT_URL=wss://livekit.jouwdomein.com
VITE_STUN_URL=stun:turn.jouwdomein.com:3478
VITE_TURN_URL=turn:turn.jouwdomein.com:3478?transport=udp,turn:turn.jouwdomein.com:3478?transport=tcp
VITE_TURN_USERNAME=turnuser
VITE_TURN_PASSWORD=replace-with-strong-turn-password
VITE_ICE_TRANSPORT_POLICY=all

TURN_REALM=turn.jouwdomein.com
TURN_USERNAME=turnuser
TURN_PASSWORD=replace-with-strong-turn-password
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Zonder domeinen (fallback):
# VITE_TOKEN_URL=http://<VPS_PUBLIC_IP>:3001/token
# VITE_LIVEKIT_URL=ws://<VPS_PUBLIC_IP>:7880
# VITE_STUN_URL=stun:<VPS_PUBLIC_IP>:3478
# VITE_TURN_URL=turn:<VPS_PUBLIC_IP>:3478?transport=udp,turn:<VPS_PUBLIC_IP>:3478?transport=tcp
# VITE_ICE_TRANSPORT_POLICY=relay
# TURN_REALM=<VPS_PUBLIC_IP>
